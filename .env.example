# ============================================================
# Copy this to .env.local — NEVER commit .env.local to git
# ============================================================

# Supabase project URL and anon key (required)
# Found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your deployed site URL — used for Open Graph, sitemap, robots.txt
# No trailing slash. Use https in production.
NEXT_PUBLIC_BASE_URL=https://cliniolab.com

# Google Search Console verification code (optional)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ============================================================
# Database / Storage backend
#
# Production (Cloudflare Pages): leave DB_DRIVER and STORAGE_DRIVER
# unset. D1/R2 bindings come from wrangler.toml, not env vars.
#   wrangler d1 create cliniolab
#
# Testing (Vercel): set these so the app reaches the SAME D1 database
# and R2 bucket as production, over HTTPS instead of Workers bindings
# (which Vercel can't access directly).
# ============================================================
DB_DRIVER=http
STORAGE_DRIVER=s3

# D1 HTTP API — Cloudflare dashboard → My Profile → API Tokens → create
# a token with "D1: Edit" permission. Account ID and Database ID are on
# the D1 database's Overview page (also in wrangler.toml).
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=

# R2 S3-compatible API — R2 bucket → Manage API Tokens → create a token
# with Object Read & Write, scoped to this bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ============================================================
# Resend (email)
# ============================================================
RESEND_API_KEY=
RESEND_FROM_ADDRESS=Cliniolab <hello@cliniolab.com>

# ============================================================
# Flutterwave (paid quizzes and resources - platform-collects model;
# creators withdraw earnings via payout requests, see README)
# ============================================================
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# ============================================================
# Web Push (VAPID keys for PWA notifications)
# Generate with: npx web-push generate-vapid-keys
# ============================================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ============================================================
# Cron endpoint protection (inactivity nudge emails)
# Set this, then configure an external scheduler (cron-job.org, GitHub
# Actions, etc.) to POST to /api/cron/inactivity-nudge with header:
#   x-cron-secret: <this value>
# ============================================================
CRON_SECRET=
