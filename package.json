{
  "name": "cliniolab",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "db:migrate:local": "wrangler d1 execute cliniolab --local --file=./src/db/schema.sql",
    "db:seed:local": "wrangler d1 execute cliniolab --local --file=./src/db/seed.sql",
    "db:migrate:remote": "wrangler d1 execute cliniolab --remote --file=./src/db/schema.sql",
    "db:seed:remote": "wrangler d1 execute cliniolab --remote --file=./src/db/seed.sql"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.7",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "@tanstack/react-query": "^5.100.11",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.2",
    "wrangler": "^3.99.0"
  }
}
